%%BoundingBox: 50 236 544 604
%%Pages: 0
%%EndComments
%%EndPageSetup
gsave

50 236 translate

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Drawing mode:                                 %
% mode=0: color  /  mode=1: gray  /  mode=2: bw %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/mode 2 def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Use original colors:                          %
% origcol=0: yes  /  origcol=1: no              %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/origcol 1 def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Background color  (default white)             %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/background { 1 1 1 } def
/origBack { 0.65882 0.69019 0.75294 } def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Text and Mesh color                           %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/black { 0 0 0 } def
/origBlack { 0 0 0 } def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Weight for gray conversion                    %
% Only relevant in mode=1                       %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/rweigth {.3} def
/gweigth {.5} def
/bweigth {.2} def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Opacity of the sphere                         %
% Only relevant for spherical view              %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/opaque 0.2 def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Dashing Type                                  %
% Used for the background of the sphere in b/w  %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/dash {[1 2] 0 setdash} def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Fonts                                         %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/labelFont {/Times-BoldItalic findfont 12.0 scalefont setfont} def
/textFont {/Helvetica findfont 12.0 scalefont setfont} def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% IFS                                           %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
/IFSdotsize 0.5 def
/IFSiterations 20000 def


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% END OF SETUP                                  %
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%



% evetually switch do original colors
origcol 0 eq {/background {origBack} def /black {origBlack} def} if
% extract background colors
background /blue exch def /green exch def /red exch def
/backgroundfill {blue 1 eq green 1 eq red 1 eq and and
       {newpath} {background setrgbcolor fill} ifelse} def
% define color modes
/rgb0 {setrgbcolor} def
/rgb1 {bweigth mul 3 1 roll
       gweigth mul 3 1 roll
       rweigth mul add add setgray} def
/rgb2 {blue eq 3 1 roll 
       green eq 3 1 roll 
       red eq and and {background} {black} ifelse setrgbcolor} def
% set color mode
mode 0 eq {/rgb {rgb0} def} if
mode 1 eq {/rgb {rgb1} def} if
mode 2 eq {/rgb {rgb2} def} if
% redefine of fillcolors for polygons
mode 0 eq {/fillit {eofill} def} if
mode 1 eq {/fillit {eofill} def} if
mode 2 eq {/fillit {myfill} def} if
% reset states
/backmode 0 def
/lastgray 0 def
% special setlinewidth and fill
1 setlinecap
/setlw {backmode 1 eq mode 2 eq and {opaque mul dash} if setlinewidth} def
/circlefill {backmode 1 eq mode 2 eq and {fill} {fill} ifelse} def
/pointfill {backmode 1 eq mode 2 eq and {opaque mul 0 360 arc fill} {0 360 arc fill} ifelse} def
% rgb with alpha
/rgbalpha {
  backmode 1 eq {opaque mul} if /alpha exch def /alpha1 1 alpha sub def
  alpha mul blue  alpha1 mul add 3 1 roll
  alpha mul green alpha1 mul add 3 1 roll
  alpha mul red   alpha1 mul add 3 1 roll
  rgb
} def
% special fill for polygons
/myfill {
   /col {1 1 1} def
   lastgray 0 eq {/diff 1000 def /angle1 0 def /angle2 0 def /col {1 1 1} def } if
   lastgray 1 eq {/diff 1000 def /angle1 0 def /angle2 0 def /col {0 0 0} def } if
   lastgray 2 eq {/diff 2 def /angle1 30 def /angle2 30 def} if
   lastgray 3 eq {/diff 2 def /angle1 -30 def /angle2 30 def} if
   lastgray 4 eq {/diff 2 def /angle1 -30 def /angle2 -30 def} if
   lastgray 5 eq {/diff 4 def /angle1 60 def /angle2 60 def} if
   lastgray 6 eq {/diff 4 def /angle1 -60 def /angle2 60 def} if
   lastgray 7 eq {/diff 4 def /angle1 -60 def /angle2 -60 def} if
   lastgray 8 eq {/diff 6 def /angle1 90 def /angle2 90 def} if
   lastgray 9 eq {/diff 6 def /angle1 -90 def /angle2 -90 def} if
   lastgray 10 eq {/diff 6 def /angle1 -90 def /angle2 90 def} if
   lastgray 11 eq {/diff 8 def /angle1 30 def /angle2 30 def} if
   lastgray 12 eq {/diff 8 def /angle1 -30 def /angle2 30 def} if
   lastgray 12 eq {/diff 8 def /angle1 -30 def /angle2 -30 def} if
   lastgray 13 eq {/diff 8 def /angle1 45 def /angle2 45 def} if
   lastgray 14 eq {/diff 8 def /angle1 45 def /angle2 -45 def} if
   lastgray 15 eq {/diff 8 def /angle1 -45 def /angle2 -45 def} if
   eoclip
   col setrgbcolor
   clippath fill
   0 0 0 setrgbcolor
   gsave
   angle1 rotate
   0.5 setlinewidth
   -736 diff 736 {
      /tmp exch def
      -988 tmp neg moveto
      1976 0 rlineto stroke
   } for
   grestore
   gsave
   angle2 rotate
   0.5 setlinewidth
   -736 diff 736 {
      /tmp exch def
      -988 tmp neg moveto
      1976 0 rlineto stroke
   } for
   grestore
} def
% allow special iso characters
/reencodeISO {
        dup dup findfont dup length dict begin
        { 1 index /FID ne { def }{ pop pop } ifelse
        } forall
        /Encoding ISOLatin1Encoding def
        currentdict end definefont
} def
% set font
/Times-Roman reencodeISO def
/Times-Bold reencodeISO def
/Times-Italic reencodeISO def
/Times-BoldItalic reencodeISO def
/Helvetica reencodeISO def
/Helvetica-Bold reencodeISO def
/Helvetica-Oblique reencodeISO def
/Helvetica-BoldOblique reencodeISO def
/Courier reencodeISO def
/Courier-Bold reencodeISO def
/Courier-Oblique reencodeISO def
/Courier-BoldOblique reencodeISO def
textFont


